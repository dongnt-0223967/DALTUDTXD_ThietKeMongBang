<Application x:Class="DALTUDTXD_ThietKeMongBang.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:DALTUDTXD_ThietKeMongBang"
             xmlns:vm="clr-namespace:DALTUDTXD_ThietKeMongBang.ViewModels"
             xmlns:vw="clr-namespace:DALTUDTXD_ThietKeMongBang.Views"
             StartupUri="Views/LoginView.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/UIColors.xaml"/>
                <ResourceDictionary Source="/Styles/ButtonStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Ensure that HomeViewModel and other ViewModels exist in the specified namespace -->
            <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                <vw:HomeView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
