<Window x:Class="DALTUDTXD_ThietKeMongBang.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DALTUDTXD_ThietKeMongBang.Views"
        mc:Ignorable="d"
        Title="LoginView"
        Height="550"
        Width="850"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="20">
        <Border.Background>
            <SolidColorBrush Color="#121212"/>
        </Border.Background>

        <Border CornerRadius="15" BorderThickness="1" Opacity="1">
            <Border.BorderBrush>
                <SolidColorBrush Color="#2D2D2D"/>
            </Border.BorderBrush>

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E1E1E" Offset="0"/>
                    <GradientStop Color="#121212" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="547*"/>
                    <ColumnDefinition Width="301*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- Top Buttons -->
                <Grid Grid.ColumnSpan="2">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text=" "
                               Foreground="#CCCCCC"
                               FontFamily="Montserrat"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>

                    <!-- Minimize -->
                    <Button x:Name="btnMinimize"
                            BorderThickness="0"
                            Content="-"
                            Foreground="#CCCCCC"
                            FontFamily="Montserrat"
                            Cursor="Hand"
                            Grid.Column="1"
                            FontSize="20"
                            Click="btnMinimize_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#333333"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18"
                                        Height="18"
                                        CornerRadius="10"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                    <!-- Close -->
                    <Button x:Name="btnClose"
                            BorderThickness="0"
                            Content="x"
                            Foreground="#CCCCCC"
                            FontFamily="Montserrat"
                            Cursor="Hand"
                            Grid.Column="2"
                            FontSize="16"
                            Click="btnClose_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#E53935"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18"
                                        Height="18"
                                        CornerRadius="10"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>

                <!-- Login Form -->
                <StackPanel Width="280"
                            Grid.Row="1"
                            Orientation="Vertical"
                            Margin="284,35,0,0"
                            HorizontalAlignment="Left"
                            Grid.ColumnSpan="2">

                    <Image Source="/Images/engineering.png"
                           Width="100"
                           Height="100"
                           HorizontalAlignment="Center"/>

                    <TextBlock Margin="0,10,0,0"
                               Text="SF Cal"
                               Foreground="#E0E0E0"
                               FontSize="25"
                               FontWeight="Medium"
                               FontFamily="Montserrat"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Tính toán và thiết kế móng băng"
                               Foreground="#9E9E9E"
                               FontSize="15"
                               FontWeight="Medium"
                               FontFamily="Montserrat"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <!-- Username -->
                    <TextBlock Text="Username"
                               Foreground="#9E9E9E"
                               FontSize="15"
                               FontWeight="Light"
                               FontFamily="Montserrat"/>

                    <Border Height="35"
                            Margin="0,5,0,15"
                            Background="#2D2D2D"
                            CornerRadius="4"
                            BorderThickness="0,0,0,1"
                            BorderBrush="#424242">

                        <Grid>

                            <Image Source="/Images/user.png"
                                   Width="16"
                                   Height="16"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   HorizontalAlignment="Left"/>

                            <TextBox x:Name="txtUser"
                                     FontSize="13"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Montserrat"
                                     FontWeight="Heavy"
                                     Foreground="#E0E0E0"
                                     CaretBrush="#9E9E9E"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalAlignment="Center"
                                     VerticalContentAlignment="Center"
                                     Padding="25,0,5,0"/>

                        </Grid>

                    </Border>

                    <!-- Password -->
                    <TextBlock Text="Password"
                               Foreground="#9E9E9E"
                               FontSize="15"
                               FontWeight="Light"
                               FontFamily="Montserrat"/>

                    <Border Height="35"
                            Margin="0,5,0,15"
                            Background="#2D2D2D"
                            CornerRadius="4"
                            BorderThickness="0,0,0,1"
                            BorderBrush="#424242">

                        <Grid>

                            <Image Source="/Images/lock.png"
                                   Width="16"
                                   Height="16"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   HorizontalAlignment="Left"/>

                            <PasswordBox x:Name="txtPassword"
                                         FontSize="13"
                                         FontFamily="Montserrat"
                                         FontWeight="Heavy"
                                         Foreground="#E0E0E0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Padding="25,0,5,0"/>

                        </Grid>

                    </Border>

                    <TextBlock x:Name="txtError"
                               Foreground="#E53935"
                               FontSize="13"
                               FontFamily="Montserrat"/>

                    <!-- Login Button -->
                    <Button x:Name="btnLogin"
                            BorderThickness="0"
                            Content="LOG IN"
                            Foreground="#FFFFFF"
                            FontFamily="Montserrat"
                            Cursor="Hand"
                            FontSize="16"
                            Margin="0,25,0,0"
                            Click="btnLogin_Click"
                            Background="#6474e5"
                            Height="40"
                            Width="150"
                            HorizontalAlignment="Center"/>

                    <!-- Reset -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,15,0,0">

                        <TextBlock Text="Forgot Password ?"
                                   Foreground="#9E9E9E"
                                   FontSize="15"
                                   FontFamily="Montserrat"/>

                        <TextBlock Text="Reset"
                                   Foreground="#6474e5"
                                   FontSize="15"
                                   FontWeight="Medium"
                                   FontFamily="Montserrat"
                                   Cursor="Hand"
                                   Margin="5,0,0,0"
                                   MouseLeftButtonDown="Reset_Click"/>

                    </StackPanel>

                </StackPanel>

            </Grid>
        </Border>
    </Border>
</Window>