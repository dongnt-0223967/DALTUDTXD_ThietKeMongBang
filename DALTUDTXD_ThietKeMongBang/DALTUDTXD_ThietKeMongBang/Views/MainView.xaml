<Window x:Class="DALTUDTXD_ThietKeMongBang.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DALTUDTXD_ThietKeMongBang.Views"
        mc:Ignorable="d"
        Title="MainView" Height="700" Width="1300"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">
    <Border CornerRadius="10"
            BorderThickness="1">

        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2D2D2D" Offset="0"/>
                <GradientStop Color="#3A3A3A" Offset="0.5"/>
                <GradientStop Color="#242424" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="250"/>

                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Navigation Menu-->
            <Border CornerRadius="10,0,0,10"
                        Grid.Column="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.7">
                        <GradientStop Color="#2D2D30" Offset="0"/>
                        <GradientStop Color="LightSkyBlue" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <StackPanel>

                    <!--Logo-->
                    <StackPanel Orientation="Horizontal"
                                Height="35"
                                Margin="15,25,0,40">

                        <Image Source="/Images/engineering.png" Height="40"/>
                        <TextBlock Text="S.F CAL"
                                   Foreground="White"
                                   FontSize="26"
                                   FontFamily="Montserrat"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>

                    </StackPanel>

                    <!--Menu Buttons-->
                    <RadioButton Style="{StaticResource menuButton}"
                                 Tag="Red"
                                 IsChecked="True"
                                 GroupName="MainMenu"
                                 Command="{Binding ShowHomeViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/Home.ico" Width="30" Height="40" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="Trang chủ" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>

                    </RadioButton>

                    <RadioButton Style="{StaticResource menuButton}"
                                 Tag="Red"
                                 GroupName="MainMenu"
                                 Command="{Binding ShowCal1ViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/floodedhouse.png" Width="30" Height="50" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="Số liệu nền đất" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource menuButton}"
                                 Tag="Red"
                                 GroupName="MainMenu"
                                 Command="{Binding ShowCal2ViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/Information.png" Width="30" Height="50" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="Thông số móng cơ bản" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource menuButton}"
                                 Tag="Red"
                                 GroupName="MainMenu"
                                 Command="{Binding ShowCal3ViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/download.png" Width="30" Height="50" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="Tải trọng" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource menuButton}"
                                 Tag="Red"
                                 GroupName="MainMenu"
                                 Command="{Binding ShowCal4ViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/math.png" Width="30" Height="50" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="Tính toán móng" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource menuButton}"
                                 Tag="Red"
                                 GroupName="MainMenu"
                                 Command="{Binding ShowCal5ViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/Images/abacus.png" Width="30" Height="50" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBlock Text="Báo cáo kết quả" Foreground="White" FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </RadioButton>
                    
                </StackPanel>
                
            </Border>

            <!--Main Section-->
            <Border CornerRadius="0,10,10,0"
                    Grid.Column="1">

                <Border.Background>
                    <LinearGradientBrush StartPoint="1,1" EndPoint="0,0">
                        <GradientStop Color="#363636" Offset="0"/>
                        <GradientStop Color="#1E1E1E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <!--Thanh điều khiển-->
                        <RowDefinition Height="25"/>
                        <!--Tiêu đề / Ghi chú-->
                        <RowDefinition Height="35"/>
                        <!--Phần nội dung-->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!--Control bar-->
                    <StackPanel x:Name="pnlControlBar"
                                Grid.Row="0"
                                Orientation="Horizontal"
                                FlowDirection="RightToLeft"
                                Background="Transparent"
                                Margin="0,0,5,0"
                                MouseLeftButtonDown="pnlControlBar_MouseLeftButtonDown"
                                MouseEnter="pnlControlBar_MouseEnter">
                        <Button x:Name="btnClose"
                                Style="{StaticResource controlButton}"
                                Tag="{StaticResource color4}"
                                Click="btnClose_Click">
                            <Image Source="/Images/ControlButton/close.png" Width="15" Height="25" VerticalAlignment="Center" Margin="0"/>
                        </Button>

                        <Button x:Name="btnMaximize"
                                Style="{StaticResource controlButton}"
                                Tag="{StaticResource color6}"
                                Click="btnMaximize_Click">
                            <Image Source="/Images/ControlButton/move.png" Width="15" Height="25" VerticalAlignment="Center" Margin="0"/>
                        </Button>

                        <Button x:Name="btnMinimize"
                                Style="{StaticResource controlButton}"
                                Tag="{StaticResource color8}"
                                Click="btnMinimize_Click">
                            <Image Source="/Images/ControlButton/minimize.png" Width="15" Height="25" VerticalAlignment="Center" Margin="0"/>
                        </Button>
                    </StackPanel>

                    <Grid Grid.Row="1">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        
                        <!--caption-->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            
                        </StackPanel>
                    </Grid>
                    <!--Nội Dung-->
                    <ContentControl Content="{Binding CurrentChildView}"
                                    Grid.Row="2"
                                    Margin="25"
                                    BorderThickness="20"/>
                </Grid>

            </Border>
        </Grid>
    </Border>
</Window>
